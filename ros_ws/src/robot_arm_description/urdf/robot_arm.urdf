<?xml version="1.0"?>
<robot name="robot_arm">

  <!-- ===== MATERIALS ===== -->
  <material name="black"> <color rgba="0.2 0.2 0.2 1.0"/> </material>
  <material name="grey">  <color rgba="0.5 0.5 0.5 1.0"/> </material>
  <material name="blue">  <color rgba="0.2 0.4 0.8 1.0"/> </material>
  <material name="red">   <color rgba="0.8 0.2 0.2 1.0"/> </material>
  <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/> </material>

  <!-- ===== BASE (fixed to world) ===== -->
  <link name="base_link">
    <visual>
      <geometry><cylinder radius="0.06" length="0.01"/></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <!-- J1: base yaw (rotates around Z) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.005" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="0.5" velocity="1.0"/>
  </joint>
  <link name="link1">
    <visual>
      <geometry><box size="0.08 0.08 0.06"/></geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- J2: shoulder (rotates around Y) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.108" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="0.5" velocity="1.0"/>
  </joint>
  <link name="link2">
    <visual>
      <geometry><box size="0.04 0.04 0.042"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- J3: elbow (rotates around Y) -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.042" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="0.5" velocity="1.0"/>
  </joint>
  <link name="link3">
    <visual>
      <geometry><box size="0.04 0.04 0.051"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- J4: wrist roll (axis along forearm) -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.051" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="0.3" velocity="1.0"/>
  </joint>
  <link name="link4">
    <visual>
      <geometry><box size="0.04 0.04 0.038"/></geometry>
      <material name="red"/>
    </visual>
  </link>

  <!-- J5: wrist pitch -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.038" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="0.3" velocity="1.0"/>
  </joint>
  <link name="link5">
    <visual>
      <geometry><box size="0.03 0.03 0.045"/></geometry>
      <material name="red"/>
    </visual>
  </link>

  <!-- J6: gripper (zero=closed, positive=open) -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="1.57" effort="0.3" velocity="1.0"/>
  </joint>
  <link name="link6">
    <visual>
      <geometry><box size="0.02 0.02 0.032"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <!-- Virtual tool tip -->
  <link name="tool_tip"/>
  <joint name="tool_fixed" type="fixed">
    <parent link="link6"/>
    <child link="tool_tip"/>
    <origin xyz="0 0 0.032" rpy="0 0 0"/>
  </joint>

</robot>
